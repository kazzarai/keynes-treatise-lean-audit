Keynes.pr_swap : ∀ (p q h : Prop), Keynes.Pr p (q ∧ h) * Keynes.Pr q h = Keynes.Pr q (p ∧ h) * Keynes.Pr p h
Keynes.th_14_46_1_src : ∀ (x h a : Prop) (l : List Prop),
  Keynes.Pr x (Keynes.bigAnd (a :: l) ∧ h) * Keynes.Pr (Keynes.bigAnd (a :: l)) h * Keynes.Pr x h ^ l.length *
      Keynes.prodPr (a :: l) (x ∧ h) =
    Keynes.Pr (Keynes.bigAnd (a :: l)) (x ∧ h) * (List.map (fun b => Keynes.Pr x (b ∧ h) * Keynes.Pr b h) (a :: l)).prod
Keynes.th_14_47_1_src : ∀ (x h : Prop) (l : List Prop),
  Keynes.Pr (Keynes.bigAnd l ∧ x) h * Keynes.prodPr l (x ∧ h) * Keynes.Pr x h ^ l.length =
    Keynes.Pr x h * Keynes.Pr (Keynes.bigAnd l) (x ∧ h) * (List.map (fun a => Keynes.Pr (a ∧ x) h) l).prod
Keynes.th_14_48_src : ∀ (x x' h a : Prop) (l : List Prop),
  Keynes.Pr x (Keynes.bigAnd (a :: l) ∧ h) * Keynes.Pr (Keynes.bigAnd (a :: l)) h * Keynes.Pr x h ^ l.length *
        Keynes.prodPr (a :: l) (x ∧ h) *
      (Keynes.Pr (Keynes.bigAnd (a :: l)) (x' ∧ h) *
        (List.map (fun b => Keynes.Pr x' (b ∧ h) * Keynes.Pr b h) (a :: l)).prod) =
    Keynes.Pr x' (Keynes.bigAnd (a :: l) ∧ h) * Keynes.Pr (Keynes.bigAnd (a :: l)) h * Keynes.Pr x' h ^ l.length *
        Keynes.prodPr (a :: l) (x' ∧ h) *
      (Keynes.Pr (Keynes.bigAnd (a :: l)) (x ∧ h) *
        (List.map (fun b => Keynes.Pr x (b ∧ h) * Keynes.Pr b h) (a :: l)).prod)
Keynes.th_14_48_1_src : ∀ (a x x' h : Prop) (l : List Prop),
  Keynes.Pr (Keynes.bigAnd (a :: l)) (x ∧ h) * Keynes.Pr (Keynes.bigAnd l) (x' ∧ h) *
      Keynes.Pr a (Keynes.bigAnd l ∧ x' ∧ h) =
    Keynes.Pr (Keynes.bigAnd (a :: l)) (x' ∧ h) * Keynes.Pr (Keynes.bigAnd l) (x ∧ h) *
      Keynes.Pr a (Keynes.bigAnd l ∧ x ∧ h)
Keynes.th_14_49_step_src : ∀ (G G' xk x0 xk' x0' : ℝ),
  G' < G → x0 < xk → xk - x0 = x0' - xk' → x0 * G + x0' * G' < xk * G + xk' * G'
Keynes.th_14_49_1_src : ∀ (x h : Prop) (l : List Prop),
  Keynes.Pr (Keynes.bigAnd l) h =
    Keynes.Pr (Keynes.bigAnd l) (x ∧ h) * Keynes.Pr x h + Keynes.Pr (Keynes.bigAnd l) (¬x ∧ h) * Keynes.Pr (¬x) h
