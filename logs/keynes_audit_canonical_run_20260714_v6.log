Keynes.th_17_58_closed : ∀ (x : ℕ → Prop) (t h : Prop) (aa q : ℝ),
  Keynes.Pr t h = aa →
    (∀ (n k : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x k ∧ t ∧ h) = 1) →
      (∀ (n : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x n ∧ ¬t ∧ h) = q) →
        ∀ (n : ℕ), Keynes.Pr (Keynes.chainN x n) h = aa + (1 - aa) * q ^ n
Keynes.th_17_58_1_src : ∀ (x : ℕ → Prop) (t h : Prop) (aa : ℝ),
  Keynes.Pr t h = aa →
    (∀ (n k : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x k ∧ t ∧ h) = 1) →
      (∀ (n : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x n ∧ ¬t ∧ h) = 0) →
        ∀ (n : ℕ), Keynes.Pr (Keynes.chainN x (n + 2)) h = Keynes.Pr (Keynes.chainN x (n + 1)) h
Keynes.th_17_58_2_src : ∀ (x : ℕ → Prop) (t h : Prop) (aa q : ℝ),
  Keynes.Pr t h = aa →
    (∀ (n k : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x k ∧ t ∧ h) = 1) →
      (∀ (n : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x n ∧ ¬t ∧ h) = q) →
        0 < aa →
          aa < 1 →
            0 < q →
              q < 1 →
                ∀ (n : ℕ),
                  Keynes.Pr (Keynes.chainN x (n + 2)) h * Keynes.Pr (Keynes.chainN x n) h >
                    Keynes.Pr (Keynes.chainN x (n + 1)) h ^ 2
Keynes.th_17_58_3_src : ∀ (x : ℕ → Prop) (t h : Prop) (aa : ℝ),
  Keynes.Pr t h = aa →
    (∀ (n k : ℕ), Keynes.Pr (x (n + 1)) (Keynes.chainN x k ∧ t ∧ h) = 1) →
      ∀ (n : ℕ), Keynes.Pr t (Keynes.chainN x n ∧ h) * Keynes.Pr (Keynes.chainN x n) h = aa
