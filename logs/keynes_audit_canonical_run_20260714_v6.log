Keynes.th_17_57_ii_n2 : ∀ (E a₁ a₂ h : Prop),
  Keynes.Pr (E ∧ (True ∧ ¬a₁) ∧ ¬a₂) h = 0 →
    Keynes.Pr E h = Keynes.Pr (E ∧ a₁) h + Keynes.Pr (E ∧ a₂) h - Keynes.Pr ((E ∧ a₂) ∧ a₁) h
Keynes.th_17_57_1_mr : ∀ (E N a h : Prop),
