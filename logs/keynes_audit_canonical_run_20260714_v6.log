  Keynes.Pr (Keynes.bigOr l) (a ∧ h) = 1 →
    Keynes.chainExclusive (List.map (fun p => p ∧ a) l) h → Keynes.Pr a h = Keynes.sumPr (List.map (fun p => p ∧ a) l) h
Keynes.th_14_25_1_src : ∀ (a h p : Prop) (l : List Prop),
  Keynes.Pr (Keynes.bigOr l) (a ∧ h) = 1 →
    Keynes.chainExclusive (List.map (fun q => q ∧ a) l) h →
      Keynes.Pr p (a ∧ h) * Keynes.sumPr (List.map (fun q => q ∧ a) l) h = Keynes.Pr (p ∧ a) h
Keynes.th_14_26_src : ∀ (a h : Prop), Keynes.Pr (¬h) h = 0 → Keynes.Pr a h = Keynes.Pr (a ∨ ¬h) h
