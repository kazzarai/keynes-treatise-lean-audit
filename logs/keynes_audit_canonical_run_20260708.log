Keynes.th_17_57_3 : ∀ (causes : List Prop) (E h : Prop),
  Keynes.Pr (Keynes.bigOr causes) (E ∧ h) = 1 →
    List.Pairwise (fun a b => Keynes.Pr (a ∧ b) h = Keynes.Pr a h * Keynes.Pr b h) causes →
