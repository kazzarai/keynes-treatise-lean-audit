Keynes.th_17_56_1 : ∀ (α₁ α₂ E h : Prop),
  Keynes.Pr (α₁ ∨ α₂) (E ∧ h) = 1 →
    Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h ≤ Keynes.Pr E h ∧
      Keynes.Pr E (α₂ ∧ h) * Keynes.Pr α₂ h ≤ Keynes.Pr E h ∧
        Keynes.Pr E h ≤ Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h + Keynes.Pr E (α₂ ∧ h) * Keynes.Pr α₂ h ∧
          Keynes.Pr E h ≤ 1 - Keynes.Pr α₁ h + Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h ∧
            Keynes.Pr E h ≤ 1 - Keynes.Pr α₂ h + Keynes.Pr E (α₂ ∧ h) * Keynes.Pr α₂ h
Keynes.th_17_56_2 : ∀ (α₁ α₂ E h : Prop),
  Keynes.Pr (α₁ ∨ α₂) (E ∧ h) = 1 → Keynes.Pr E h ≤ Keynes.Pr E (α₁ ∧ h) + Keynes.Pr E (α₂ ∧ h)
Keynes.th_17_56_3 : ∀ (α₁ α₂ E h : Prop),
  Keynes.Pr (α₁ ∨ α₂) (E ∧ h) = 1 →
    Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h ≤ Keynes.Pr E h ∧
      Keynes.Pr E h ≤ 1 - Keynes.Pr α₁ h + Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h
Keynes.th_17_56_4 : ∀ (α₁ α₂ E h : Prop),
  Keynes.Pr (α₁ ∨ α₂) (E ∧ h) = 1 → Keynes.Pr E h ≤ Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h + Keynes.Pr α₂ h
Keynes.th_17_56_5 : ∀ (α₁ α₂ E h : Prop),
  Keynes.Pr (α₁ ∨ α₂) (E ∧ h) = 1 →
    Keynes.Pr α₁ (α₂ ∧ h) = Keynes.Pr α₁ h →
      Keynes.Pr E (α₁ ∧ h) * Keynes.Pr α₁ h + Keynes.Pr E (α₂ ∧ h) * Keynes.Pr α₂ h - Keynes.Pr α₁ h * Keynes.Pr α₂ h ≤
        Keynes.Pr E h
Keynes.th_17_57 : ∀ (causes : List Prop) (E h : Prop),
  Keynes.Pr (Keynes.bigOr causes) (E ∧ h) = 1 →
    Keynes.Pr E h =
      Keynes.sumPr (List.map (fun p => p ∧ E) causes) h - Keynes.overlapSum (List.map (fun p => p ∧ E) causes) h
Keynes.th_17_57_2 : ∀ (causes : List Prop) (E h : Prop),
  Keynes.Pr (Keynes.bigOr causes) (E ∧ h) = 1 → ∀ α ∈ causes, Keynes.Pr E (α ∧ h) * Keynes.Pr α h ≤ Keynes.Pr E h
Keynes.th_17_57_6 : ∀ (αr E h : Prop),
  Keynes.Pr E h ≠ 0 → Keynes.Pr αr (E ∧ h) = Keynes.Pr E (αr ∧ h) * Keynes.Pr αr h / Keynes.Pr E h
Keynes.th_17_58 : ∀ (h : Prop) (l : List Prop), Keynes.Pr (Keynes.bigAnd l) h = Keynes.chainProd l h
Keynes.th_17_58_1 : ∀ (h : Prop) (l : List Prop), (∀ p ∈ l, ∀ (e : Prop), Keynes.Pr p e = 1) → Keynes.chainProd l h = 1
Keynes.th_17_58_2 : ∀ (h p : Prop) (l : List Prop), Keynes.chainProd (p :: l) h ≤ Keynes.chainProd l h
