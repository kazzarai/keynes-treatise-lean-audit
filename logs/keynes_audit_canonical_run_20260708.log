Keynes.th_14_47_1 : ∀ (causes : List Prop) (E h : Prop),
  Keynes.Pr (Keynes.bigOr causes) h = 1 →
    List.Pairwise (fun a b => Keynes.Pr (a ∧ b) h = 0) causes →
      Keynes.Pr E h ≠ 0 →
        ∀ α ∈ causes,
          Keynes.weightSum causes E h ≠ 0 →
            Keynes.Pr α (E ∧ h) * Keynes.weightSum causes E h = Keynes.Pr E (α ∧ h) * Keynes.Pr α h
Keynes.th_14_49_1 : ∀ (causes : List Prop) (E h : Prop),
  Keynes.Pr (Keynes.bigOr causes) h = 1 →
    List.Pairwise (fun a b => Keynes.Pr (a ∧ b) h = 0) causes →
